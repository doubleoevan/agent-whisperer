{
  "name": "@agent-whisperer/database",
  "description": "Drizzle schema, Postgres client, row-level-security tenant helpers, and outbox enqueue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "pnpm exec eslint .",
    "db:generate": "doppler run -- drizzle-kit generate",
    "db:migrate": "doppler run -- tsx scripts/migrate.ts",
    "db:studio": "doppler run -- drizzle-kit studio",
    "check:tenant-isolation": "doppler run -- tsx scripts/check-tenant-isolation.ts"
  },
  "dependencies": {
    "@agent-whisperer/domain": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@agent-whisperer/eslint-config": "workspace:*",
    "@agent-whisperer/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
