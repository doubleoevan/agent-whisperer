{
  "name": "@agent-whisperer/config",
  "description": "Zod-validated, typed environment configuration",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "pnpm exec eslint .",
    "check": "doppler run -- tsx scripts/check.ts"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@agent-whisperer/eslint-config": "workspace:*",
    "@agent-whisperer/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
