{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM (local gateway)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "{env:LITELLM_API_KEY}"
      },
      "models": {
        "chat": { "name": "chat (load-balanced)" },
        "chat-anthropic": { "name": "chat (Anthropic only)" },
        "chat-openai": { "name": "chat (OpenAI only)" }
      }
    }
  },
  "model": "litellm/chat-anthropic",
  "mcp": {
    "agent-whisperer": {
      "type": "local",
      "command": ["pnpm", "--filter", "@agent-whisperer/mcp", "dev"],
      "enabled": true
    }
  }
}
