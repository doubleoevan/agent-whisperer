# Local Docker Postgres defaults. Real values flow through Doppler later.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_whisperer

# App role password (created by init script). The app role is non-superuser,
# non-owner — RLS policies apply to it. Used by the runtime client.
APP_DB_PASSWORD=app

# Convenience URLs (consumed by drizzle-kit + the runtime client until Step 3).
DATABASE_URL=postgres://app:app@localhost:5432/agent_whisperer
DATABASE_URL_ADMIN=postgres://postgres:postgres@localhost:5432/agent_whisperer
